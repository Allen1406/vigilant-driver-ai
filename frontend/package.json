{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "start-app": "concurrently \"npm run dev\" \"electron .\"",
    "build-app": "npm run build && electron-builder"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "electron-builder": "^24.13.3",
    "electron": "^41.0.4",
    "vite": "^8.0.1"
  },
  "build": {
    "appId": "com.driver.ai",
    "productName": "DriverAI",
    "files": [
  "dist/**/*",
  "main.js",
  {
    "from": "../backend/dist",
    "to": "backend/dist",
    "filter": ["**/*"]
  }
],
    "win": {
      "target": "nsis"
    }
  }
}
